# ─────────────────────────────────────────────────────────────
#  Конфигурация инфраструктуры VLESS+Reality.
#  Скопируйте в .env и отредактируйте:  cp .env.example .env
#  Файл .env НЕ коммитится (.gitignore) — он может содержать секреты.
# ─────────────────────────────────────────────────────────────

# Домен (опционально). Нужен для:
#   - реального TLS-сертификата Hysteria2 (ACME Let's Encrypt)
#   - схемы за CDN Cloudflare
# Для базового Reality на чистом IP домен НЕ нужен — оставьте пустым.
DOMAIN=

# ── Сайт-донор Reality (Часть 1, §6 — это ~80% качества маскировки) ──
# Требования: иностранный, не заблокирован в РФ, TLS 1.3 + HTTP/2, без редиректов.
# Хорошие дефолты: www.microsoft.com, www.apple.com, www.cloudflare.com.
# ИЗБЕГАЙТЕ Google-доменов.
REALITY_SNI=www.microsoft.com
REALITY_DEST=www.microsoft.com:443

# ── Порты ──
VLESS_PORT=443            # строго 443 — порт обычного HTTPS, ломать смысла нет
HY2_PORT=443             # Hysteria2 (UDP). Может совпадать с VLESS — это разные протоколы (TCP/UDP)
HY2_HOP_RANGE=20000:50000 # диапазон UDP для port hopping (пусто = выключить)
PANEL_PORT=2053          # порт 3X-UI, если ставите панель
SSH_PORT=22              # поменяйте, если меняли порт SSH

# ── Администрирование ──
ADMIN_USER=myadmin       # отдельный sudo-пользователь (не работаем под root)

# ── Telegram-уведомления и бэкапы (опционально, Часть 2 §17) ──
# Создайте бота через @BotFather, узнайте chat_id через @userinfobot.
TG_BOT_TOKEN=
TG_CHAT_ID=

# ── Пути (обычно менять не нужно) ──
XRAY_CONFIG=/usr/local/etc/xray/config.json
HY2_CONFIG=/etc/hysteria/config.yaml
STATE_DIR=/etc/vpn-dimosi   # здесь хранятся секреты (chmod 600)
